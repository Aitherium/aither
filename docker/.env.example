# AitherOS ADK - Environment Configuration
# Copy this file to .env and fill in the values you need.

# ---------- Gateway ----------
# API key for the AitherOS cloud gateway (optional, for MCP bridge access)
AITHER_API_KEY=
AITHER_GATEWAY_URL=https://gateway.aitherium.com

# ---------- LLM Backend ----------
# Which LLM backend to use: ollama | openai | anthropic | vllm
AITHER_LLM_BACKEND=ollama

# Model override (leave blank for backend default)
AITHER_MODEL=

# ---------- Ollama (default) ----------
# Host URL for Ollama. When running in Docker, use host.docker.internal
# to reach Ollama on the host machine.
OLLAMA_HOST=http://host.docker.internal:11434

# ---------- Cloud Providers (optional) ----------
# Only needed if AITHER_LLM_BACKEND is set to openai or anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- vLLM (optional, GPU profile) ----------
# Model to serve when using the vllm-primary service
VLLM_MODEL=meta-llama/Llama-3.2-3B-Instruct
